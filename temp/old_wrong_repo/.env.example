# AXIOM Environment Configuration
# Copy this file to .env and fill in your values.
# All settings can also be overridden via environment variables at runtime.

# ============================================================
# Google AI / Gemini API
# ============================================================
# Required for:
#   - LLM agent calls (gemini-2.5-flash, gemini-2.5-pro via google-adk)
#   - Customer memory vector embeddings (gemini-embedding-2)
# Get your key from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_google_api_key_here   # alias; either key name is accepted

# ============================================================
# Redis
# ============================================================
# Used for: session state hashes, event streams, vector memory, research cache.
# Local default: redis://localhost:6379
# Cloud (e.g. Upstash): rediss://user:password@host:port
REDIS_URL=redis://localhost:6379

# ============================================================
# LinkUp Search API (Tier 3 Research)
# ============================================================
# Used for external knowledge retrieval during research queries.
# If absent, the system logs a warning and skips real search.
# Get it from: https://app.linkup.so
LINKUP_API_KEY=your_linkup_api_key_here

# ============================================================
# Public Gateway URL
# ============================================================
# Required for the Agent Card manifest (.well-known/agent-card.json)
# and for external A2A peers to reach this gateway.
# Use ngrok or any reverse proxy during local development.
NGROK_URL=https://your-ngrok-url.ngrok.app

# ============================================================
# Runtime Mode
# ============================================================
# development  (default) — in-memory fallbacks + mock accounts enabled
# test                   — pytest fixtures; no real API calls required
# grading                — no mocks, no silent fallbacks; hard failures
AXIOM_MODE=development

# ============================================================
# Model Overrides (optional — defaults set in config.py)
# ============================================================
# Change these to experiment with different models without touching code.
# INTAKE_MODEL=gemini-2.5-flash
# FORMATTER_MODEL=gemini-2.5-flash
# REASONING_MODEL=gemini-2.5-pro
# RESEARCH_MODEL=gemini-2.5-flash
# EMBEDDING_MODEL=gemini-embedding-2
# EMBEDDING_DIMENSIONS=768

# ============================================================
# Generation Settings (optional)
# ============================================================
# INTAKE_TEMPERATURE=0.1
# INTAKE_MAX_TOKENS=1024
# REASONING_TEMPERATURE=0.3
# REASONING_MAX_TOKENS=2048
# FORMATTER_TEMPERATURE=0.0
# FORMATTER_MAX_TOKENS=1024
# RESEARCH_TEMPERATURE=0.1
# RESEARCH_MAX_TOKENS=1024

# ============================================================
# Agent Ports (optional)
# ============================================================
# PORT_GATEWAY=8080
# PORT_PERSONAL=8081
# PORT_CS=8082
# PORT_RESEARCH=8083

# ============================================================
# Circuit Breaker (optional)
# ============================================================
# Short window (default 120s) prevents spoofed agentId from causing long bans.
# CIRCUIT_FAILURE_THRESHOLD=3
# CIRCUIT_BAN_SECONDS=120

# ============================================================
# SSE / AG-UI (optional)
# ============================================================
# SSE_MAX_WAIT=60.0
# SSE_HEARTBEAT_INTERVAL=15.0
